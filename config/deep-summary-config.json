{
  "fallback_chain": ["gemini-cli", "deepseek-api"],
  "gemini_cli": {
    "timeout_ms": 90000,
    "model_override": null
  },
  "deepseek_api": {
    "model": "deepseek-chat",
    "endpoint": "https://api.deepseek.com/chat/completions",
    "timeout_ms": 60000,
    "max_retries": 1,
    "secrets_file": "",
    "secrets_key": "DEEPSEEK_API_KEY"
  },
  "ui": {
    "modal_max_width_px": 900,
    "show_raw_json_button": true
  }
}
