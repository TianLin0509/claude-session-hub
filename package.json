{
  "name": "claude-session-hub",
  "version": "0.5.0",
  "description": "Chat-style multi-session terminal manager for Claude Code",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node test-e2e.js",
    "test:mobile": "node tests/mobile/test-all.js",
    "test:mobile:auth": "node tests/mobile/test-auth.js",
    "test:mobile:rest": "node tests/mobile/test-rest.js",
    "test:mobile:ws": "node tests/mobile/test-ws.js",
    "dist": "electron-builder --win"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "bcryptjs": "^2.4.3",
    "dompurify": "^3.4.0",
    "express": "^4.22.1",
    "marked": "^18.0.1",
    "node-pty": "^1.0.0",
    "qrcode": "^1.5.4",
    "uuid": "^10.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.claude-session-hub",
    "productName": "Claude Session Hub",
    "win": {
      "target": "nsis",
      "icon": "claude-wx.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "claude-wx.ico",
      "uninstallerIcon": "claude-wx.ico",
      "createDesktopShortcut": true
    },
    "files": [
      "main.js",
      "core/**/*",
      "renderer/**/*",
      "renderer-mobile/**/*",
      "scripts/**/*",
      "claude-wx.ico",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts"
      }
    ]
  }
}
